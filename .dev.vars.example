# Google OAuth Configuration
# Copy this file to .dev.vars and fill in your values

# Required for Google OAuth - get from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Callback URL for local development
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/api/auth/google/callback
GOOGLE_REDIRECT_URIS=http://127.0.0.1:8787/api/auth/google/callback
